{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning",
      "Microsoft.Hosting.Lifetime": "Information",
      "ApiServer": "Information",
      "ApiServer.Presentation.Http.Middleware": "Warning"
    }
  },
  "Jwt": {
    "Issuer": "LobbyAuth",
    "Audience": "ApiServer",
    "AccessTokenMinutes": 10,
    "PrivateKeyPemPath": "4.Infrastructure/Security/keys/lobby_private.pem",
    "PublicKeyPemPath": "4.Infrastructure/Security/keys/lobby_public.pem"
  },
  "SystemApiKey": "CHANGE_ME_SYSTEM_API_KEY",
  "Db": {
    "ConnectionString": "Host=localhost;Port=5432;Database=lobbydb;Username=app_user;Password=CHANGE_ME_POSTGRES_PASSWORD;Pooling=true;Maximum Pool Size=50"
  },
  "ControlPlane": {
    "Address": "http://localhost:5001",
    "TimeoutMs": 3000,
    "Secret": "CHANGE_ME"
  },
  "Security": {
    "RefreshTokenDays": 14,
    "RefreshTokenLength": 64,
    "RevokeAllOnReuse": true
  },
  "Redis": {
    "ConnectionString": "localhost:6380,password=CHANGE_ME_REDIS_PASSWORD,abortConnect=False",
    "Database": 1,
    "Prefix": "lobby:"
  },
  "Mongo": {
    "Enabled": false,
    "ConnectionString": "mongodb://localhost:27017",
    "DatabaseName": "rhythm_analytics",
    "GameResultsCollection": "game_results",
    "ConnectTimeoutSeconds": 5,
    "ServerSelectionTimeoutSeconds": 5,
    "OperationTimeoutSeconds": 5,
    "WriteConcernTimeoutSeconds": 5,
    "ReconcileIntervalSeconds": 15,
    "ReconcileBatchSize": 100,
    "DefaultHistoryLimit": 20,
    "MaxHistoryLimit": 100
  },
  "Steam": {
    "Enabled": true,
    "AppId": "480",
    "PublisherKey": "",
    "WebApiBaseUrl": "https://partner.steam-api.com"
  },
  "ItemDataPath": "../GameServer/Content/Data/Json"
}
