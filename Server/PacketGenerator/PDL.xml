<?xml version="1.0" encoding="utf-8" ?>
<PDL>

	<!-- 클라 -> 게임서버: 최초 접속/검증 -->
	<packet name="CS_JoinGame">
		<string name="matchId"/>
		<string name="uid"/>
		<string name="ticket"/><!-- RS256 -->
		<int name="protoVer"/><!-- 예: 3 -->
		<string name="nonce"/><!-- 1회성 -->
		<string name="clientVer"/><!-- 예: "u6-0.1.3" -->
		<string name="platform"/><!-- "Windows","Android" 등 -->
	</packet>

	<!-- 게임서버 -> 클라: 환영/환경 -->
	<packet name="SC_Welcome">
		<string name="matchId"/>
		<int name="slot"/>
		<long name="serverTimeMs"/>
		<int name="tickRate"/><!-- 30,60 등 -->
		<int name="startTick"/><!-- 0 or 사전 동기값 -->
		<string name="map"/>
		<int name="seed"/>
		<int name="latencyBudgetMs"/><!-- 시작 예약 지연여유 -->
		<string name="startPolicy"/><!-- "AllLoaded" 등 -->
	</packet>

	<!-- 클라 -> 게임서버: 로딩 완료 -->
	<packet name="CS_Loaded">
		<string name="matchId"/>
		<string name="uid"/>
	</packet>

	<!-- 게임서버 -> 클라: 양측 로딩 완료 알림 -->
	<packet name="SC_AllPlayersLoaded">
		<string name="matchId"/>
		<list name="players">
			<string name="uid"/>
			<int name="slot"/>
			<bool name="loaded"/>
		</list>
	</packet>

	<!-- 게임서버 -> 클라: 시작 시각 고정 통보 -->
	<packet name="SC_GameBegin">
		<string name="matchId"/>
		<long name="startAtMs"/><!-- 서버 기준 절대 시각 -->
		<int  name="startTick"/><!-- 동시 시작 tick -->
	</packet>

	<!-- 공통 -->
	<packet name="SC_Error">
		<int name="code"/>
		<string name="message"/>
	</packet>
	<packet name ="SC_Warn">
		<int name ="code"/>
		<string name="msg"/>
	</packet>
	<packet name="CS_Ping">
		<int    name="seq"/>
		<long   name="clientSendMs"/>
	</packet>

	<packet name="SC_Pong">
		<int    name="seq"/>
		<long   name="clientSendMs"/>
		<long   name="serverRecvMs"/>
		<long   name="serverSendMs"/>
	</packet>
	<!-- GameLogic-->
	
	
	<!-- RhythmTest-->

	<packet name="SC_InitGame">
		<double name="ActionWindowMs"/>
		<int name="MapWidth"/>
		<int name="MapHeight"/>
		<string name ="MapName"/>
		
		<list name="PlayerActorIds">
			<int name="ActorId"/>
		</list>

		<int name="MyActorId"/>

		<list name="SpawnEntities">
			<int  name="EntityId"/>
			<int  name="EntityType"/>
			<int  name="OwnerSlot"/>
			<int  name="X"/>
			<int  name="Y"/>
			<int  name="Hp"/>
		</list>
	</packet>


	<packet name ="SC_BeatSync">
		<long name ="ServerTimeMs"/>
		<long name ="SongStartServerTimeMs"/>
		<double name ="Bpm"/>
		<int name ="BaseBeatDivision"/>
		<long name ="BeatIndex"/>
	</packet>

	<packet name ="CS_ActionRequest">
		<int name ="ActorId"/>
		<int name ="ActionKind"/>	 <!--/ Skill / Wait 등-->
		<int name ="TargetX"/>	
		<int name ="TargetY"/>
		<long name ="ClientSendTimeMs"/>
	</packet>

	<packet name ="SC_BeatActions">
		<long name ="BeatIndex"/>
		<list name ="BeatActionResult">
			<int name="ActorId"/>
			<int name="ActionKind"/>	<!--/ Skill / Wait 등-->	
			<int name="FromX"/>
			<int name="FromY"/>
			<int name="ToX"/>
			<int name="ToY"/>
			<bool name="Accepted"/>
				
			<list name ="HpUpdate">
				<int name="EntityId"/>
				<int name="NewHp"/>
			</list>
		</list>
	</packet>

	<packet name="SC_BeatTelegraphs">
		<long name="BeatIndex"/>
		<list name="Telegraphs">
			<int name="CasterId"/>
			<int name="StyleId"/>
			<int name="DurationBeats"/>
			<int name="Shape"/>			<!-- 0:Cells, 1:Diamond, 2:Rect, 3:Line ... -->
			<int name="OriginType"/>	<!-- 0:Self,1:Target,2:Point -->
			<int name="OriginX"/>		<!-- OriginType==Point일 때 -->
			<int name="OriginY"/>
			<int name="ParamA"/>		<!-- shape 파라미터 (radius/width/len 등) -->
			<int name="ParamB"/>
			<list name="Cells">			<!-- Shape==Cells 일 때만 사용 -->
				<int name="X"/>
				<int name="Y"/>
			</list>
		</list>
	</packet>


	<packet name ="SC_EntityDespawn">
		<long name="BeatIndex"/>
		<int name ="EntityId"/>
	</packet>

	<!-- RhythmTest-->
	

	

</PDL>

