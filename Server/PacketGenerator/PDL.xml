<?xml version="1.0" encoding="utf-8" ?>
<PDL>

	<packet name="CS_Handshake">
		<string name="ticketId"/>
		<string name="clientNonce"/>
	</packet>

	<packet name="SC_HandshakeOk">
		<int name="State"/>		<!-- 1=TOWN, 2=GAME -->
		<long name="Epoch"/>
		<string name="Uid"/>
		<string name="RoomId"/>		<!-- GAME일 때만 값, TOWN이면 "" -->
		<long name="ServerNowMs"/>		<!-- 선택: 클라 타임보정용 -->
		<int name="LeaseTtlSec"/>		<!-- 선택: 디버그/클라 표시용 -->
	</packet>

	<packet name="SC_HandshakeFail">
		<int name="errorCode"/>
		<string name="message"/>
	</packet>

	<packet name="SC_ForcedDisconnect">
		<int name="Reason"/>		<!-- 1=MovedToGame, 2=DuplicateLogin, 3=EpochSuperseded -->
		<long name="NewEpoch"/>		<!-- 서버가 알고 있으면 넣고, 모르면 0 -->
		<string name="Message"/>
	</packet>



	<!-- 게임서버 -> 클라: 양측 로딩 완료 알림 -->
	<packet name="SC_AllPlayersLoaded">
		<string name="matchId"/>
		<list name="players">
			<string name="uid"/>
			<int name="slot"/>
			<bool name="loaded"/>
		</list>
	</packet>

	<!-- 게임서버 -> 클라: 시작 시각 고정 통보 -->
	<packet name="SC_GameBegin">
		<string name="matchId"/>
		<long name="startAtMs"/><!-- 서버 기준 절대 시각 -->
		<int  name="startTick"/><!-- 동시 시작 tick -->
	</packet>

	<!-- 공통 -->
	<packet name="SC_Error">
		<int name="code"/>
		<string name="message"/>
	</packet>
	<packet name ="SC_Warn">
		<int name ="code"/>
		<string name="msg"/>
	</packet>
	<packet name="CS_Ping">
		<int    name="seq"/>
		<long   name="clientSendMs"/>
	</packet>

	<packet name="SC_Pong">
		<int    name="seq"/>
		<long   name="clientSendMs"/>
		<long   name="serverRecvMs"/>
		<long   name="serverSendMs"/>
	</packet>
	<!-- GameLogic-->
	
	
	<!-- RhythmTest-->

	<packet name="SC_InitGame">
		<double name="ActionWindowMs"/>
		<int name="MapWidth"/>
		<int name="MapHeight"/>
		<string name ="MapName"/>
		
		<list name="PlayerActorIds">
			<int name="ActorId"/>
		</list>

		<int name="MyActorId"/>

		<list name="SpawnEntities">
			<int  name="EntityId"/>
			<int  name="EntityType"/>
			<int  name="OwnerSlot"/>
			<int  name="X"/>
			<int  name="Y"/>
			<int  name="Hp"/>
		</list>
	</packet>


	<packet name ="SC_CalibResult">
		<int name="DiffMs"/>
		<long name ="BeatIndex"/>
		<long name ="ServerNowMs"/>
	</packet>
	<packet name ="CS_CalibHit">
		<long name ="ClientSendTimeMs"/>
		<long name ="BeatIndex"/>
	</packet>


	<packet name ="SC_BeatSync">
		<long name ="ServerSendTimeMs"/>
		<long name ="ClientSendTimeMs"/>
		<long name ="SongStartServerTimeMs"/>
		<double name ="Bpm"/>
		<int name ="BaseBeatDivision"/>
		<long name ="BeatIndex"/>
	</packet>

	<packet name ="CS_ActionRequest">
		<int name ="ActorId"/>
		<int name ="ActionKind"/>	 <!--/ Skill / Wait 등-->
		<int name ="TargetX"/>	
		<int name ="TargetY"/>
		<long name ="ClientSendTimeMs"/>
	</packet>

	<packet name ="SC_BeatActions">
		<long name ="BeatIndex"/>
		<list name ="BeatActionResult">
			<int name="ActorId"/>
			<int name="ActionKind"/>	<!--/ Skill / Wait 등-->	
			<int name="FromX"/>
			<int name="FromY"/>
			<int name="ToX"/>
			<int name="ToY"/>
			<bool name="Accepted"/>
				
			<list name ="HpUpdate">
				<int name="EntityId"/>
				<int name="NewHp"/>
			</list>
		</list>
	</packet>

	<packet name="SC_BeatTelegraphs">
		<long name="BeatIndex"/>
		<list name="Telegraphs">
			<int name="CasterId"/>
			<int name="StyleId"/>
			<int name="DurationBeats"/>
			<int name="Shape"/>			<!-- 0:Cells, 1:Diamond, 2:Rect, 3:Line ... -->
			<int name="OriginType"/>	<!-- 0:Self,1:Target,2:Point -->
			<int name="OriginX"/>		<!-- OriginType==Point일 때 -->
			<int name="OriginY"/>
			<int name="ParamA"/>		<!-- shape 파라미터 (radius/width/len 등) -->
			<int name="ParamB"/>
			<list name="Cells">			<!-- Shape==Cells 일 때만 사용 -->
				<int name="X"/>
				<int name="Y"/>
			</list>
		</list>
	</packet>


	<packet name ="SC_EntityDespawn">
		<long name="BeatIndex"/>
		<int name ="EntityId"/>
	</packet>

	
	
	<!-- RhythmTest-->



</PDL>

