# PostgreSQL
POSTGRES_USER=app_user
POSTGRES_PASSWORD=change-me-postgres-password
POSTGRES_DB=lobbydb
POSTGRES_PORT=5432

# Redis
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PASSWORD=change-me-redis-password

# MongoDB (keep local passwords URI-safe: letters, digits, hyphen)
MONGO_ROOT_USERNAME=root_admin
MONGO_ROOT_PASSWORD=change-me-mongo-root-password
MONGO_APP_DATABASE=rhythm_analytics
MONGO_APP_USERNAME=rhythm_api
MONGO_APP_PASSWORD=change-me-mongo-app-password
MONGO_PORT=27017

# ASP.NET Core (replace SYSTEM_API_KEY with a random secret of at least 32 characters)
SYSTEM_API_KEY=change-me-to-a-random-32-character-secret
ConnectionStrings__AuthDb=Host=db;Port=5432;Database=lobbydb;Username=app_user;Password=change-me-postgres-password;Pooling=true;Maximum Pool Size=50
ASPNETCORE_ENVIRONMENT=Development

# Public endpoint defaults for docker-compose
SERVER_PUBLIC_HOST=127.0.0.1
TOWN_PUBLIC_PORT=13221
GAME_PUBLIC_PORT=13222
CONTROLPLANE_PORT=5001
API_PORT=5000
