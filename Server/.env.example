# PostgreSQL
POSTGRES_USER=app_user
POSTGRES_PASSWORD=change-me-postgres-password
POSTGRES_DB=lobbydb
POSTGRES_PORT=5432

# Redis
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PASSWORD=change-me-redis-password

# ASP.NET Core
ConnectionStrings__AuthDb=Host=db;Port=5432;Database=lobbydb;Username=app_user;Password=change-me-postgres-password;Pooling=true;Maximum Pool Size=50
ASPNETCORE_ENVIRONMENT=Development

# Public endpoint defaults for docker-compose
SERVER_PUBLIC_HOST=127.0.0.1
TOWN_PUBLIC_PORT=13221
GAME_PUBLIC_PORT=13222
CONTROLPLANE_PORT=5001
API_PORT=5000
