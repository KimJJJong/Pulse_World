# This .gitignore file should be placed at the root of your Unity project directory
#
# Get latest from https://github.com/github/gitignore/blob/main/Unity.gitignore
#
.utmp/
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/
*.log

# MemoryCaptures can get excessive in size.
# They also could contain extremely sensitive data
/[Mm]emoryCaptures/

# Recordings can get excessive in size
/[Rr]ecordings/

# Uncomment this line if you wish to ignore the asset store tools plugin
# /[Aa]ssets/AssetStoreTools*

# Autogenerated Jetbrains Rider plugin
/[Aa]ssets/Plugins/Editor/JetBrains*

# Visual Studio cache directory
.vs/

# Gradle cache directory
.gradle/

# Autogenerated VS/MD/Consulo solution and project files
ExportedObj/
.consulo/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity3D generated meta files
*.pidb.meta
*.pdb.meta
*.mdb.meta

# appsettings 
**/appsettings.*.json
**/appsettings.json
!Server/ApiServer/appsettings.json
!Server/ApiServer/appsettings.Development.json
!Server/ControlPlaneServer/appsettings.json
!Server/GameServer/appsettings.json
!Server/GameServer/appsettings.Game.json
!Server/GameServer/appsettings.Town.json

# Unity3D generated file on crash reports
sysinfo.txt

# Builds
*.apk
*.aab
*.unitypackage
*.unitypackage.meta
*.app

# Public portfolio branch omits large binary assets.
*.fbx
*.fbx.meta
*.png
*.png.meta
*.jpg
*.jpg.meta
*.jpeg
*.jpeg.meta
*.psd
*.psd.meta
*.tga
*.tga.meta
*.exr
*.exr.meta
*.wav
*.wav.meta
*.mp3
*.mp3.meta
*.ogg
*.ogg.meta
*.ttf
*.ttf.meta
*.otf
*.otf.meta
*.dll
*.dll.meta
*.so
*.so.meta
*.a
*.a.meta
*.lib
*.lib.meta
*.pdf
*.pdf.meta
*.zip
*.zip.meta
*.dae
*.dae.meta

# Crashlytics generated file
crashlytics-build.properties

# Packed Addressables
/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.bin*

# Temporary auto-generated Android Assets
/[Aa]ssets/[Ss]treamingAssets/aa.meta
/[Aa]ssets/[Ss]treamingAssets/aa/*


##############FMOD
# Never ignore DLLs in the FMOD subfolder.
!/[Aa]ssets/Plugins/FMOD/**/lib/*

# Don't ignore images and gizmos used by FMOD in the Unity Editor.
!/[Aa]ssets/Gizmos/FMOD/*
!/[Aa]ssets/Editor Default Resources/FMOD/*

# Ignore the Cache folder since it is updated locally.
/[Aa]ssets/Plugins/FMOD/Cache/*

# Ignore bank files in the StreamingAssets folder.
/[Aa]ssets/StreamingAssets/**/*.bank
/[Aa]ssets/StreamingAssets/**/*.bank.meta

# If the source bank files are kept outside of the StreamingAssets folder then these can be ignored.
# Log files can be ignored.
fmod_editor.log






# .NET / C# build outputs
[Bb]in/
[Oo]bj/

# Rider / VSCode / ��Ÿ
.idea/
.vscode/

# NuGet
*.nupkg
/packages/

# OS
.DS_Store
Thumbs.db

# Local/private files and generated portfolio artifacts
.env
.env.*
**/.env
**/.env.*
!**/.env.example
.artifacts/
.codex-backups/
.claude/
Client/.claude/
Client/GeneratedAssets_deleted/

# Local logs and runtime output
**/logs/
*.log
**/build_log.txt
**/build_output.txt
**/build_errors.txt
**/startup_log.txt
Client/Assets/resources_paths.txt

# Local AI/Unity tooling dependencies
Client/Assets/Synaptic AI Pro/MCPServer/node_modules/
Client/Assets/Synaptic AI Pro/MCPServer/node_modules.meta

# Local JWT/certificate material
Server/ApiServer/4.Infrastructure/Security/keys/
Server/GameServer/keys/
Server/GameServer/_buildcheck/

# Allow Server .csproj and .sln files
!Server/**/*.csproj
!Server/**/*.sln

# Ignore Postgres data generated by Docker
Server/data/
