--- !u!114 &8684932773479165738
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 179043710461512132}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 67bc6a0e0a8de954a82e0c967b5fbf1a, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::HomeMapRealmUI
  _realms:
  - RealmId: plains
    DisplayName: Golden Plains
    Description: "\uB9C8\uC744\uB85C \uC774\uB3D9 \uAC00\uB2A5\uD55C \uC911\uC2EC
      \uD3C9\uC57C\uC785\uB2C8\uB2E4. \uD604\uC7AC Town \uC785\uC7A5 \uD2F0\uCF13
      \uAC80\uC99D \uD750\uB984\uACFC \uB3D9\uC77C\uD558\uAC8C \uB3D9\uC791\uD569\uB2C8\uB2E4."
    RequiredTicket: Town Pass
    SceneName: TownMap
    Button: {fileID: 991195119330230322}
    Highlight: {fileID: 1600124094115719283}
  - RealmId: forest
    DisplayName: Whispering Forest
    Description: "\uC6B8\uCC3D\uD55C \uC232\uACFC \uC791\uC740 \uB9C8\uC744\uC774
      \uC788\uB294 \uCD08\uBC18 \uC601\uC5ED\uC785\uB2C8\uB2E4. \uB9AC\uB4EC \uC65C\uACE1\uC774
      \uAC00\uC7A5 \uC57D\uD574 \uC785\uC7A5 \uC900\uBE44\uC5D0 \uC801\uD569\uD569\uB2C8\uB2E4."
    RequiredTicket: Town Pass
    SceneName: Town_Forest
    Button: {fileID: 4005450082494221935}
    Highlight: {fileID: 8195406372989460542}
  - RealmId: snow
    DisplayName: Frostpeak Mountains
    Description: "\uC5BC\uC5B4\uBD99\uC740 \uBC15\uC790\uC640 \uC9C0\uC5F0 \uC785\uB825\uC774
      \uC11E\uC774\uB294 \uC124\uC0B0 \uC601\uC5ED\uC785\uB2C8\uB2E4. \uBC29\uC5B4
      \uC7A5\uBE44 \uD655\uC778\uC744 \uAD8C\uC7A5\uD569\uB2C8\uB2E4."
    RequiredTicket: "\uC5C6\uC74C"
    SceneName: 
    Button: {fileID: 2309478696110526823}
    Highlight: {fileID: 1168083083544063882}
  - RealmId: ruins
    DisplayName: Ancient Ruins
    Description: "\uBB34\uB108\uC9C4 \uC720\uC801\uACFC \uC794\uD5A5 \uD328\uD134\uC774
      \uACB9\uCE58\uB294 \uACE0\uB300 \uC601\uC5ED\uC785\uB2C8\uB2E4. \uBCF5\uD569
      \uB9AC\uB4EC \uC804\uD22C\uAC00 \uB4F1\uC7A5\uD569\uB2C8\uB2E4."
    RequiredTicket: "\uC5C6\uC74C"
    SceneName: 
    Button: {fileID: 4389921499200428234}
    Highlight: {fileID: 5224287287675467282}
  - RealmId: lake
    DisplayName: Sapphire Lake
    Description: "\uD30C\uB3C4 \uB9AC\uB4EC\uACFC \uBC18\uD5A5 \uC804\uD22C\uAC00
      \uB9CC\uB098\uB294 \uC218\uC0C1 \uC601\uC5ED\uC785\uB2C8\uB2E4. \uAE34 \uD328\uD134\uC744
      \uC548\uC815\uC801\uC73C\uB85C \uCC98\uB9AC\uD574\uC57C \uD569\uB2C8\uB2E4."
    RequiredTicket: "\uC5C6\uC74C"
    SceneName: 
    Button: {fileID: 3219067503259014790}
    Highlight: {fileID: 7958348602271812909}
  - RealmId: desert
    DisplayName: Sandworn Wastes
    Description: "\uBAA8\uB798 \uC704\uB85C \uB290\uB9B0 \uBC15\uB3D9\uC774 \uD750\uB974\uB294
      \uACE0\uC5F4 \uC601\uC5ED\uC785\uB2C8\uB2E4. \uD68C\uD53C \uD0C0\uC774\uBC0D\uC774
      \uB290\uB9AC\uAC8C \uD754\uB4E4\uB9BD\uB2C8\uB2E4."
    RequiredTicket: "\uC5C6\uC74C"
    SceneName: 
    Button: {fileID: 3501047820081116475}
    Highlight: {fileID: 5774857003083829012}
  - RealmId: volcano
    DisplayName: Ember Volcano
    Description: "\uACFC\uC5F4\uB41C \uBC15\uB3D9\uC774 \uBE60\uB974\uAC8C \uC99D\uD3ED\uB418\uB294
      \uD654\uC0B0 \uC601\uC5ED\uC785\uB2C8\uB2E4. \uC9E7\uC740 \uC785\uB825 \uD310\uB2E8\uC774
      \uC911\uC694\uD569\uB2C8\uB2E4."
    RequiredTicket: "\uC5C6\uC74C"
    SceneName: 
    Button: {fileID: 1672384850297371064}
    Highlight: {fileID: 7307823783233778407}
